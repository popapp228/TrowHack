-- Функция для URL-кодирования
local function urlEncode(str)
    local chars = {
        ["%"] = "%%25",
        ["?"] = "%%3F",
        ["="] = "%%3D",
        ["&"] = "%%26",
        ["/"] = "%%2F",
        [":"] = "%%3A",
        [" "] = "%%20",
        ["#"] = "%%23",
        ["+"] = "%%2B",
        ["@"] = "%%40",
        ["$"] = "%%24",
        [","] = "%%2C",
        [";"] = "%%3B",
    }
    
    local encoded = str:gsub(".", function(c)
        if chars[c] then
            return chars[c]
        else
            return c
        end
    end)
    return encoded
end

-- Функция замены ссылки
local function ConvertLink(link)
    if link:find("linkvertise%.com") then
        return link:gsub("linkvertise%.com", "linkvertise.lol")
    end
    
    if link:find("links%.lootlabs%.gg") or link:find("lockr%.so") or link:find("workink%.net") or link:find("work%.ink") then
        local encoded = urlEncode(link)
        return "https://rip.linkvertise.lol/bypass?url=" .. encoded
    end
    
    return nil
end

-- Функция копирования
local function copyToClipboard(text)
    local SetClipboard = setclipboard or toclipboard or set_clipboard
    if SetClipboard then
        SetClipboard(text)
        return true
    end
    return false
end

